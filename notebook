    "# === Section 4: Fraud RATE by Hour (the real story) ===\n",
    "\n",
    "hourly_stats = df.groupby('Hour').agg(\n",
    "    total_transactions=('Class', 'count'),\n",
    "    frauds=('Class', 'sum')\n",
    ").reset_index()\n",
    "\n",
    "hourly_stats['fraud_rate_pct'] = (hourly_stats['frauds'] / hourly_stats['total_transactions']) * 100\n",
    "hourly_stats['risk_multiplier'] = hourly_stats['fraud_rate_pct'] / fraud_rate\n",
    "\n",
    "# Sort to find the worst hours\n",
    "hourly_stats_sorted = hourly_stats.sort_values('fraud_rate_pct', ascending=False)\n",
