    "ax[0].bar(fraud_by_hour.index, fraud_by_hour.values, color='#d62728', alpha=0.8)\n",
    "ax[0].set_title('Fraud Transactions by Hour of Day', fontsize=14, fontweight='bold')\n",
    "ax[0].set_xlabel('Hour')\n",
    "ax[0].set_ylabel('Number of Frauds')\n",
    "ax[0].set_xticks(range(24))\n",
