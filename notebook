   "source": [
    "# === Section 1: The Fraud Problem at a Glance ===\n",
    "\n",
    "# Total fraud count and rate\n",
    "total_transactions = len(df)\n",
    "total_frauds = df['Class'].sum()\n",
    "fraud_rate = (total_frauds / total_transactions) * 100\n",
    "\n",
    "print(f\"Total transactions: {total_transactions:,}\")\n",
    "print(f\"Total frauds: {total_frauds:,}\")\n",
    "print(f\"Fraud rate: {fraud_rate:.4f}%\")\n",
    "print(f\"Legitimate rate: {100 - fraud_rate:.4f}%\")\n",
    "print()\n",
    "\n",
    "# Money at stake\n",
    "total_amount = df['Amount'].sum()\n",
    "fraud_amount = df[df['Class'] == 1]['Amount'].sum()\n",
    "legitimate_amount = df[df['Class'] == 0]['Amount'].sum()\n",
    "\n",
    "print(f\"Total transaction volume: €{total_amount:,.2f}\")\n",
    "print(f\"Fraud transaction volume: €{fraud_amount:,.2f}\")\n",
    "print(f\"Legitimate transaction volume: €{legitimate_amount:,.2f}\")\n",
    "print(f\"Fraud share of money: {(fraud_amount / total_amount) * 100:.4f}%\")"
   ]
